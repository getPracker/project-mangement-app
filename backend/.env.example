# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection
# Replace with your MongoDB connection string (e.g., mongodb://localhost:27017/taskmanager or Atlas URI)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/taskmanager

# Authentication
# Use a strong, random string for your JWT secret
JWT_SECRET=your_super_secret_random_string_here
JWT_EXPIRE=30d